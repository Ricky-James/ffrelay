---
import Layout from '../layouts/Layout.astro';
import eventData from '../data/event.json';

const currentYear = new Date().getFullYear();
const title = `Privacy Policy | ${eventData.name}`;
---

<Layout title={title} description={`Privacy policy for the ${eventData.name} website.`}>
  <main id="main-content" class="policy-page">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl py-24">
      <a href="/" class="back-link">← Back to {eventData.name}</a>

      <h1 class="text-3xl sm:text-4xl font-bold mt-8 mb-2 gradient-text">Privacy Policy</h1>
      <p class="text-slate-500 text-sm mb-12">Last updated: May {currentYear}</p>

      <div class="prose-section">
        <h2>1. Information We Collect</h2>
        <p>
          This is a static informational site for the {eventData.name}. We do not collect personal
          information directly through this site.
        </p>
        <p>
          We do not use cookies, tracking pixels, or analytics scripts of our own.
        </p>

        <h2>2. Third-Party Services</h2>
        <p>This site embeds and loads resources from the following third-party services:</p>
        <ul>
          <li>
            <strong>Twitch</strong> — the live stream and chat are embedded from twitch.tv. Twitch's
            own cookies and tracking apply within those embeds. See their
            <a href="https://www.twitch.tv/p/legal/privacy-notice/" target="_blank" rel="noopener">privacy notice</a>.
          </li>
          <li>
            <strong>YouTube</strong> — if YouTube content is embedded or linked, YouTube's privacy
            terms apply.
          </li>
          <li>
            <strong>Iconify</strong> — icons may be loaded on demand from <code>api.iconify.design</code>.
          </li>
        </ul>
        <p>
          Each of these services may log your IP address as part of normal operation. Please review
          their respective privacy policies for details.
        </p>

        <h2>3. Changes to This Policy</h2>
        <p>
          This policy may be updated periodically. The date at the top of this page reflects the
          most recent revision.
        </p>
      </div>
    </div>
  </main>
</Layout>

<style>
  .policy-page {
    background-color: var(--bg);
    min-height: 100vh;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    color: var(--text-dim);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  .back-link:hover {
    color: var(--accent);
  }

  .prose-section h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    margin: 2rem 0 0.75rem;
  }
  .prose-section p {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .prose-section ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose-section li {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 0.4rem;
  }
  .prose-section a {
    color: var(--accent);
    transition: opacity 0.2s ease;
  }
  .prose-section a:hover {
    opacity: 0.8;
  }
  .prose-section code {
    font-family: monospace;
    font-size: 0.875em;
    color: var(--text-dim);
    background: var(--bg-card);
    padding: 0.1em 0.35em;
    border-radius: 0.25rem;
  }
</style>
