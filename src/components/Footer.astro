---
import { localeFromAstro, t, type Locale } from '../lib/i18n';

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? localeFromAstro(Astro);

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
// No /ja/privacy or /ja/terms — JA pages link back to the unprefixed EN routes.
const privacyHref = `${base}privacy`;
const termsHref = `${base}terms`;
---

<footer id="site-footer" class="site-footer">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
    <p class="footer-line">
      <a href={privacyHref}>{t('footer.privacy', lang)}</a>
      &nbsp;·&nbsp;<a href={termsHref}>{t('footer.terms', lang)}</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background: var(--footer-bg);
    border-top: 1px solid var(--footer-border);
    padding: 1.25rem 0;
  }
  .footer-line {
    color: #64748b;
    font-size: 0.8rem;
    text-align: center;
    margin: 0;
  }
  .footer-line a {
    color: inherit;
    transition: color 0.2s ease;
  }
  .footer-line a:hover {
    color: var(--accent);
  }
</style>
