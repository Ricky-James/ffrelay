---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import eventData from '../data/event.json';
import { csvExportUrl } from '../lib/sheetUrl';
import { buildGameNameMap, localeFromAstro, t, tField, type Locale } from '../lib/i18n';

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? localeFromAstro(Astro);

const localizedEventName = tField(eventData, 'name', lang);
const title = `${t('schedule.metaTitle', lang)} | ${localizedEventName}`;
const description = t('schedule.metaDescription', lang, { eventName: localizedEventName });

const CSV_URL = csvExportUrl(eventData.sheet.sheetId, eventData.sheet.tabs.schedule);
const INFO_URL = csvExportUrl(eventData.sheet.sheetId, eventData.sheet.tabs.info);
const SPLITS_URL = csvExportUrl(eventData.sheet.sheetId, eventData.sheet.tabs.splits);
const POLL_MS = 60_000;
const START_DATE = eventData.startDate;

const NAME_MAP_JSON = JSON.stringify(buildGameNameMap(lang));

const STRINGS_JSON = JSON.stringify({
  endOfEvent: t('schedule.endOfEvent', lang),
  noRunsScheduled: t('schedule.noRunsScheduled', lang),
  sheetFormatUnexpected: t('schedule.sheetFormatUnexpected', lang),
  statusUpdated: t('schedule.statusUpdated', lang),
  statusLastFailed: t('schedule.statusLastFailed', lang),
  commentaryLabel: t('schedule.commentaryLabel', lang),
  pillLive: t('schedule.pillLive', lang),
  pillDone: t('schedule.pillDone', lang),
  pillUpcoming: t('schedule.pillUpcoming', lang),
  loadingStatus: t('schedule.loadingStatus', lang),
});
---

<Layout title={title} description={description}>
  <Header />
  <main
    id="main-content"
    class="schedule-page"
    data-csv-url={CSV_URL}
    data-info-url={INFO_URL}
    data-splits-url={SPLITS_URL}
    data-poll-ms={POLL_MS}
    data-start-date={START_DATE}
    data-locale={lang}
    data-name-map={NAME_MAP_JSON}
    data-strings={STRINGS_JSON}
  >
    <section id="schedule-placeholder" class="page-intro pre-event">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
        <p class="eyebrow">{t('schedule.eyebrowPre', lang)}</p>
        <h1 class="page-heading">{t('schedule.heading', lang)}</h1>
        <p class="page-lead">{t('schedule.placeholderLead', lang)}</p>
      </div>
    </section>

    <div id="schedule-content" hidden>
      <section class="page-intro">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
          <p class="eyebrow">{t('schedule.eyebrow', lang)}</p>
          <h1 class="page-heading">{t('schedule.heading', lang)}</h1>
          <p class="page-lead">
            <strong set:html={t('schedule.tzLead', lang, { tz: '<span id="user-tz">—</span>' })} />
          </p>
          <p class="page-lead">{t('schedule.aggressiveLead', lang)}</p>
          <p class="page-lead">{t('schedule.updatedLead', lang)}</p>
          <p class="status" id="schedule-status" aria-live="polite">{t('schedule.loadingStatus', lang)}</p>
        </div>
      </section>

      <div class="schedule-table-wrap">
        <table class="schedule-table" aria-describedby="schedule-status">
          <thead>
            <tr>
              <th scope="col" class="col-game">{t('schedule.colGame', lang)}</th>
              <th scope="col" class="col-start">{t('schedule.colStart', lang)}</th>
              <th scope="col" class="col-end">{t('schedule.colEnd', lang)}</th>
              <th scope="col" class="col-dur">{t('schedule.colDuration', lang)}</th>
              <th scope="col" class="col-state">{t('schedule.colStatus', lang)}</th>
            </tr>
          </thead>
          <tbody id="schedule-body">
            <tr class="placeholder-row">
              <td colspan="5">{t('schedule.loadingStatus', lang)}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .schedule-page {
    background: var(--bg);
    min-height: 100vh;
    padding-top: 4rem;
  }
  .page-intro {
    padding: 4rem 0 2rem;
  }
  .eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }
  .page-heading {
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .page-lead {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 50rem;
    margin-bottom: 1rem;
  }
  .page-lead #user-tz {
    color: var(--text);
    font-weight: 600;
  }
  .status {
    color: var(--text-dim);
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    margin: 0;
  }
  .status.is-stale {
    color: #fbbf24;
  }
  [data-theme='light'] .status.is-stale {
    color: #b45309;
  }
</style>

<style is:global>
  .schedule-table-wrap {
    width: calc(100vw - 2rem);
    margin-left: calc(50% - 50vw + 1rem);
    padding: 0 1rem 5rem;
    overflow-x: auto;
  }
  @media (min-width: 1024px) {
    .schedule-table-wrap {
      width: min(100vw - 4rem, 1100px);
      margin-left: 50%;
      transform: translateX(-50%);
      padding-left: 0;
      padding-right: 0;
    }
  }

  .schedule-table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.75rem;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.015);
    font-size: 0.9rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  .schedule-table thead {
    background: rgba(251, 191, 36, 0.04);
  }
  .schedule-table th {
    padding: 0.75rem 1rem;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fbbf24;
    border-bottom: 1px solid rgba(251, 191, 36, 0.2);
    white-space: nowrap;
    text-align: left;
  }
  .schedule-table th.col-dur {
    text-align: center;
  }
  .schedule-table th.col-state {
    text-align: center;
  }

  .schedule-table td {
    padding: 0.65rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    /* Game cell can stack runner + commentary; keep peers aligned to the game name on top. */
    vertical-align: top;
  }
  .schedule-table tbody tr:last-child td {
    border-bottom: 0;
  }
  .schedule-table td.col-game {
    color: var(--text);
    font-weight: 500;
  }
  .schedule-table .run-name {
    display: block;
    line-height: 1.3;
  }
  .schedule-table .run-runners {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;
    margin-top: 0.3rem;
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--text-muted);
  }
  .schedule-table .run-runner {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .schedule-table .run-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex: none;
  }
  .schedule-table .run-dot.tone-blue   { background: #38bdf8; }
  .schedule-table .run-dot.tone-yellow { background: #fde047; }
  .schedule-table .run-dot.tone-green  { background: #4ade80; }
  [data-theme='light'] .schedule-table .run-dot.tone-blue   { background: #0c4a6e; }
  [data-theme='light'] .schedule-table .run-dot.tone-yellow { background: #713f12; }
  [data-theme='light'] .schedule-table .run-dot.tone-green  { background: #14532d; }
  .schedule-table .run-commentary {
    margin-top: 0.2rem;
    font-size: 0.74rem;
    font-weight: 400;
    color: var(--text-dim);
  }
  .schedule-table .run-comm-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dimmer);
    margin-right: 0.45rem;
  }
  .schedule-table .run-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, currentColor 30%, transparent);
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s ease;
  }
  .schedule-table .run-link:hover {
    text-decoration-color: currentColor;
  }
  .schedule-table .run-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .schedule-table td.col-dur {
    text-align: center;
    white-space: nowrap;
  }
  .schedule-table td.col-state {
    white-space: nowrap;
    text-align: center;
  }
  .schedule-table td.col-start,
  .schedule-table td.col-end {
    white-space: nowrap;
    color: var(--text-muted);
  }
  .schedule-table .time-day {
    color: var(--text-dim);
    margin-right: 0.4rem;
    font-size: 0.78rem;
  }
  .schedule-table .time-clock {
    color: var(--text);
    font-weight: 500;
  }

  .schedule-table tr.day-row td {
    background: rgba(255, 255, 255, 0.025);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.5rem 1rem;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .schedule-table tr.is-done td.col-game,
  .schedule-table tr.is-done td.col-start,
  .schedule-table tr.is-done td.col-end {
    color: var(--text-dim);
  }
  .schedule-table tr.is-done td.col-dur {
    color: var(--text-dim);
  }
  .schedule-table tr.is-done .time-clock {
    color: var(--text-muted);
  }

  .schedule-table tr.is-live td {
    background: rgba(251, 191, 36, 0.08);
  }
  .schedule-table tr.is-live td.col-game {
    color: #fde047;
    font-weight: 700;
  }
  .schedule-table tr.is-live .time-clock {
    color: #fde047;
  }
  [data-theme='light'] .schedule-table tr.is-live td.col-game,
  [data-theme='light'] .schedule-table tr.is-live .time-clock {
    color: #92400e;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-dim);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }
  .pill.pill-live {
    background: rgba(251, 191, 36, 0.16);
    color: #fde047;
    border-color: rgba(251, 191, 36, 0.4);
  }
  .pill.pill-done {
    background: rgba(74, 222, 128, 0.1);
    color: #86efac;
    border-color: rgba(74, 222, 128, 0.25);
  }
  [data-theme='light'] .pill {
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.08);
    color: #475569;
  }
  [data-theme='light'] .pill.pill-live {
    background: rgba(202, 138, 4, 0.16);
    color: #92400e;
    border-color: rgba(202, 138, 4, 0.4);
  }
  [data-theme='light'] .pill.pill-done {
    background: rgba(22, 101, 52, 0.1);
    color: #166534;
    border-color: rgba(22, 101, 52, 0.25);
  }
  .pill .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
  }
  .pill.pill-live .dot {
    animation: pill-pulse 1.4s ease-in-out infinite;
  }
  @keyframes pill-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.4; transform: scale(0.7); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pill.pill-live .dot { animation: none; }
  }

  .schedule-table tr.end-row td {
    background: rgba(255, 255, 255, 0.04);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .schedule-table tr.end-row td.col-game {
    color: var(--text);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.78rem;
  }

  .schedule-table .placeholder-row td {
    padding: 1.4rem 1rem;
    color: var(--text-dim);
    text-align: center;
  }

  [data-theme='light'] .schedule-table {
    border-color: rgba(0, 0, 0, 0.08);
    background: rgba(0, 0, 0, 0.015);
  }
  [data-theme='light'] .schedule-table thead {
    background: rgba(202, 138, 4, 0.05);
  }
  [data-theme='light'] .schedule-table th {
    color: #a16207;
    border-bottom-color: rgba(202, 138, 4, 0.25);
  }
  [data-theme='light'] .schedule-table tr.day-row td {
    background: rgba(0, 0, 0, 0.03);
    border-color: rgba(0, 0, 0, 0.08);
    color: #475569;
  }
</style>

<script>
  // @ts-nocheck
  import {
    parseCsv,
    timeToSeconds,
    durationToMs,
    escapeHtml,
    gameKey,
    parseInfo,
    parseUtcDayTime,
    linkName as linkNameLib,
  } from '../lib/sheetParse';
  import { fillTemplate, intlLocaleFor, makeCompoundTranslator, readDataJson } from '../lib/clientI18n';

  const rootEl = document.getElementById('main-content');
  const CSV_URL = rootEl.dataset.csvUrl;
  const INFO_URL = rootEl.dataset.infoUrl;
  const SPLITS_URL = rootEl.dataset.splitsUrl;
  const POLL_MS = Number(rootEl.dataset.pollMs) || 60_000;
  const START_DATE = rootEl.dataset.startDate;
  const LOCALE = rootEl.dataset.locale || 'en';
  const STRINGS = readDataJson(rootEl, 'strings');
  const tGame = makeCompoundTranslator(readDataJson(rootEl, 'nameMap'), gameKey);

  const TEAM_TONE = { mog: 'blue', choco: 'yellow', tonberry: 'green' };
  const KNOWN_TEAMS = ['mog', 'choco', 'tonberry'];
  let infoMap = null;
  let lastStatusMap = new Map();

  const linkName = (p) => linkNameLib(p, 'run-link');

  const statusEl = document.getElementById('schedule-status');
  const bodyEl = document.getElementById('schedule-body');
  const tzEl = document.getElementById('user-tz');

  // Browser-resolved locale for Intl.* used in date/time output. Pages know their
  // own locale, but the user's system might be set differently — we honour the
  // page locale to keep date strings consistent with the rest of the UI.
  const intlLocale = intlLocaleFor(LOCALE);

  const userTz = Intl.DateTimeFormat().resolvedOptions().timeZone || 'local';
  // Friendly abbreviation ("BST", "EDT", "JST"), falling back to the raw IANA id.
  const tzAbbr = new Intl.DateTimeFormat(intlLocale, { timeZoneName: 'short' })
    .formatToParts(new Date())
    .find((p) => p.type === 'timeZoneName')?.value;
  const tzCity = (userTz.split('/').pop() ?? userTz).replace(/_/g, ' ');
  const tzLabel = tzAbbr && tzAbbr !== tzCity ? `${tzCity} (${tzAbbr})` : tzCity;
  if (tzEl) tzEl.textContent = tzLabel;

  const dayFmt = new Intl.DateTimeFormat(intlLocale, {
    weekday: 'long',
    month: 'long',
    day: 'numeric',
  });
  // ISO-ish YYYY-MM-DD in the user's local TZ — used as a grouping key.
  const dayKeyFmt = new Intl.DateTimeFormat('en-CA', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
  const timeFmt = new Intl.DateTimeFormat(intlLocale, {
    hour: 'numeric',
    minute: '2-digit',
  });
  const refreshClockFmt = new Intl.DateTimeFormat(intlLocale, {
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
  });

  let lastParsed = null;
  let pollHandle = null;
  let scrolledToLive = false;

  // Reveal the schedule three weeks before the event so attendees can plan around it.
  // Before that, only show it once the splits sheet has data (i.e. the event has started).
  const PRE_EVENT_REVEAL_DAYS = 21;
  function withinPreEventWindow() {
    const [y, mo, d] = START_DATE.split('-').map(Number);
    const startMs = Date.UTC(y, mo - 1, d);
    return Date.now() >= startMs - PRE_EVENT_REVEAL_DAYS * 86_400_000;
  }

  // Splits sheet → per-game progress for each team. Only game-end rows ("Final Fantasy …")
  // are tracked, matching the LiveStatus + ProgressChart parse logic.
  function parseSplitsForStatus(text) {
    const rows = parseCsv(text);
    const headerIdx = rows.findIndex((r) => /^split name/i.test((r[0] ?? '').trim()));
    if (headerIdx === -1) return null;
    const labelRow = rows[headerIdx];

    const cols = [];
    for (let i = 1; i < labelRow.length; i++) {
      const v = (labelRow[i] ?? '').trim();
      const m = v.match(/^team\s+(mog|choco|tonberry)$/i);
      if (m) cols.push({ col: i, team: m[1].toLowerCase() });
      else if (cols.length > 0) break;
    }
    if (cols.length === 0) return null;
    const teams = cols.map((c) => c.team).filter((t) => KNOWN_TEAMS.includes(t));

    const games = [];
    let anyData = false;
    for (let r = headerIdx + 1; r < rows.length; r++) {
      const row = rows[r];
      const name = (row[0] ?? '').trim();
      if (!name) continue;
      if (!/\bfinal fantasy\b/i.test(name)) continue;
      const times = {};
      for (const c of cols) {
        const secs = timeToSeconds((row[c.col] ?? '').trim());
        if (secs == null) continue;
        times[c.team] = secs;
        anyData = true;
      }
      games.push({ name, times });
    }
    return { teams, games, anyData };
  }

  function computeStatusMap(splits) {
    const { teams, games } = splits;
    const lastDone = {};
    for (const t of teams) {
      let idx = -1;
      for (let i = 0; i < games.length; i++) {
        if (games[i].times[t] != null) idx = i;
      }
      lastDone[t] = idx;
    }

    const map = new Map();
    for (let i = 0; i < games.length; i++) {
      const g = games[i];
      const allDone = teams.length > 0 && teams.every((t) => g.times[t] != null);
      const isLive = teams.some((t) => lastDone[t] + 1 === i);
      map.set(gameKey(g.name), allDone ? 'done' : isLive ? 'live' : 'upcoming');
    }
    return map;
  }

  function findColumn(headerRow, predicate) {
    for (let i = 0; i < headerRow.length; i++) {
      if (predicate((headerRow[i] ?? '').trim())) return i;
    }
    return -1;
  }

  function parseSheet(text) {
    const rows = parseCsv(text);
    const headerIdx = rows.findIndex((r) => /^game$/i.test((r[0] ?? '').trim()));
    if (headerIdx === -1) return null;
    const header = rows[headerIdx];
    const gameCol = 0;
    const durCol = findColumn(header, (h) => /^time$/i.test(h));
    const startCol = findColumn(header, (h) => /start.*utc/i.test(h));
    if (durCol === -1 || startCol === -1) return null;

    const runs = [];
    let endTime = null;
    for (let r = headerIdx + 1; r < rows.length; r++) {
      const row = rows[r];
      const name = (row[gameCol] ?? '').trim();
      const dur = (row[durCol] ?? '').trim();
      const start = (row[startCol] ?? '').trim();

      if (!name && /^end$/i.test(dur)) {
        endTime = parseUtcDayTime(start, START_DATE);
        continue;
      }
      if (!name && !start) continue;
      if (!name) continue;

      const startDate = parseUtcDayTime(start, START_DATE);
      const durMs = durationToMs(dur);
      if (!startDate || durMs == null) continue;
      runs.push({
        name,
        startDate,
        endDate: new Date(startDate.getTime() + durMs),
        durationText: dur,
      });
    }

    return { runs, endTime };
  }

  function renderState(run, statusMap) {
    const status = statusMap.get(gameKey(run.name)) || 'upcoming';
    if (status === 'done') {
      return { cls: 'is-done', pill: `<span class="pill pill-done">${escapeHtml(STRINGS.pillDone)}</span>` };
    }
    if (status === 'live') {
      return {
        cls: 'is-live',
        pill: `<span class="pill pill-live"><span class="dot"></span>${escapeHtml(STRINGS.pillLive)}</span>`,
      };
    }
    return { cls: '', pill: `<span class="pill">${escapeHtml(STRINGS.pillUpcoming)}</span>` };
  }

  function renderBody(parsed, statusMap) {
    const { runs, endTime } = parsed;
    if (!runs.length) {
      bodyEl.innerHTML =
        `<tr class="placeholder-row"><td colspan="5">${escapeHtml(STRINGS.noRunsScheduled)}</td></tr>`;
      return;
    }
    let currentDayKey = '';
    const parts = [];
    let liveRowId = null;

    runs.forEach((run, idx) => {
      const startKey = dayKeyFmt.format(run.startDate);
      if (startKey !== currentDayKey) {
        currentDayKey = startKey;
        parts.push(
          `<tr class="day-row"><td colspan="5">${escapeHtml(dayFmt.format(run.startDate))}</td></tr>`,
        );
      }
      const state = renderState(run, statusMap);
      const rowId = `run-${idx}`;
      if (state.cls === 'is-live' && !liveRowId) liveRowId = rowId;

      const startKeyForEnd = dayKeyFmt.format(run.endDate);
      const endDayChip =
        startKey !== startKeyForEnd
          ? `<span class="time-day">${escapeHtml(dayFmt.format(run.endDate).split(',')[0])}</span>`
          : '';

      const info = infoMap ? infoMap.get(gameKey(run.name)) : null;
      const runnersHtml = info && info.runners.length
        ? `<div class="run-runners">${info.runners.map((r) => (
            `<span class="run-runner"><span class="run-dot tone-${TEAM_TONE[r.team] || ''}"></span>${linkName(r)}</span>`
          )).join('')}</div>`
        : '';
      const commHtml = info && info.commentators.length
        ? `<div class="run-commentary"><span class="run-comm-label">${escapeHtml(STRINGS.commentaryLabel)}</span>${info.commentators.map(linkName).join(' · ')}</div>`
        : '';

      parts.push(
        `<tr id="${rowId}" class="${state.cls}">` +
          `<td class="col-game"><span class="run-name">${escapeHtml(tGame(run.name))}</span>${runnersHtml}${commHtml}</td>` +
          `<td class="col-start"><span class="time-clock">${escapeHtml(timeFmt.format(run.startDate))}</span></td>` +
          `<td class="col-end">${endDayChip}<span class="time-clock">${escapeHtml(timeFmt.format(run.endDate))}</span></td>` +
          `<td class="col-dur">${escapeHtml(run.durationText)}</td>` +
          `<td class="col-state">${state.pill}</td>` +
          '</tr>',
      );
    });

    if (endTime) {
      const endKey = dayKeyFmt.format(endTime);
      if (endKey !== currentDayKey) {
        parts.push(
          `<tr class="day-row"><td colspan="5">${escapeHtml(dayFmt.format(endTime))}</td></tr>`,
        );
      }
      parts.push(
        '<tr class="end-row">' +
          `<td class="col-game">${escapeHtml(STRINGS.endOfEvent)}</td>` +
          `<td class="col-start"><span class="time-clock">${escapeHtml(timeFmt.format(endTime))}</span></td>` +
          '<td class="col-end"></td>' +
          '<td class="col-dur"></td>' +
          '<td class="col-state"></td>' +
          '</tr>',
      );
    }

    bodyEl.innerHTML = parts.join('');

    if (!scrolledToLive && liveRowId) {
      const liveEl = document.getElementById(liveRowId);
      if (liveEl) {
        liveEl.scrollIntoView({ block: 'center', behavior: 'auto' });
        scrolledToLive = true;
      }
    }
  }

  function setStatus(text, stale) {
    statusEl.textContent = text;
    statusEl.classList.toggle('is-stale', !!stale);
  }

  const placeholderEl = document.getElementById('schedule-placeholder');
  const contentEl = document.getElementById('schedule-content');
  function showPlaceholder() {
    placeholderEl.hidden = false;
    contentEl.hidden = true;
  }
  function showContent() {
    placeholderEl.hidden = true;
    contentEl.hidden = false;
  }

  async function refresh() {
    try {
      const bust = `&_=${Date.now()}&r=${Math.random().toString(36).slice(2)}`;
      const [scheduleRes, infoRes, splitsRes] = await Promise.all([
        fetch(CSV_URL + bust, { cache: 'no-store' }),
        fetch(INFO_URL + bust, { cache: 'no-store' }).catch(() => null),
        fetch(SPLITS_URL + bust, { cache: 'no-store' }).catch(() => null),
      ]);

      let splitsParsed = null;
      if (splitsRes && splitsRes.ok) {
        try { splitsParsed = parseSplitsForStatus(await splitsRes.text()); } catch {}
      }
      const splitsHasData = !!(splitsParsed && splitsParsed.anyData);
      if (!splitsHasData && !withinPreEventWindow()) {
        showPlaceholder();
        return;
      }

      if (!scheduleRes.ok) throw new Error(`HTTP ${scheduleRes.status}`);
      const text = await scheduleRes.text();
      const parsed = parseSheet(text);
      if (!parsed) {
        showContent();
        setStatus(STRINGS.sheetFormatUnexpected, true);
        return;
      }
      if (infoRes && infoRes.ok) {
        try { infoMap = parseInfo(await infoRes.text()); } catch {}
      }
      showContent();
      lastParsed = parsed;
      lastStatusMap = splitsHasData ? computeStatusMap(splitsParsed) : new Map();
      renderBody(parsed, lastStatusMap);
      setStatus(
        fillTemplate(STRINGS.statusUpdated, {
          ts: refreshClockFmt.format(new Date()),
          n: parsed.runs.length,
          tz: tzLabel,
        }),
        false,
      );
    } catch (err) {
      const when = refreshClockFmt.format(new Date());
      if (lastParsed) {
        renderBody(lastParsed, lastStatusMap);
        setStatus(fillTemplate(STRINGS.statusLastFailed, { ts: when }), true);
      } else {
        showPlaceholder();
      }
    }
  }

  function startPolling() {
    if (pollHandle != null) return;
    refresh();
    pollHandle = setInterval(refresh, POLL_MS);
  }
  function stopPolling() {
    if (pollHandle != null) {
      clearInterval(pollHandle);
      pollHandle = null;
    }
  }

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) stopPolling();
    else startPolling();
  });

  startPolling();
</script>
