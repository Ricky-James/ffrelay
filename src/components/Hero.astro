---
import eventData from '../data/event.json';
import { csvExportUrl } from '../lib/sheetUrl';
import { getSocialLinks } from '../lib/socialLinks';
import {
  localeFromAstro,
  localizedTwitchHandle,
  t,
  tField,
  type Locale,
} from '../lib/i18n';

const SCHEDULE_URL = csvExportUrl(eventData.sheet.sheetId, eventData.sheet.tabs.schedule);

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? localeFromAstro(Astro);

const twitchHandle = localizedTwitchHandle(eventData, lang);
const twitchUrl = `https://twitch.tv/${twitchHandle}`;

const socialPersonal: Record<string, string | string[]> = {
  ...(eventData as unknown as Record<string, string>),
  twitch: twitchHandle,
};
const socialLinks = getSocialLinks(socialPersonal);

const eventName = tField(eventData, 'name', lang);
const tagline = tField(eventData, 'tagline', lang);
const eventDates = tField(eventData, 'eventDates', lang);

const markerIdx = (() => {
  const series = eventName.search(/SERIES\s+/i);
  if (series >= 0) return series;
  return eventName.search(/FANTASY\s+/i);
})();
const splitAt = markerIdx >= 0 ? eventName.indexOf(' ', markerIdx) : -1;
const titleLines = splitAt >= 0
  ? [eventName.slice(0, splitAt), eventName.slice(splitAt + 1)]
  : [eventName];

const relayPrefix = t('hero.relayPrefix', lang);
const watchCta = t('hero.watchCta', lang);
// Translators own the full sentence + word order; set:html is safe because the template
// is from our own JSON, not user input.
const relayHtml = `<span class="cta-event">${relayPrefix} ${eventData.eventNumber}</span>`;
const watchSentenceHtml = t('hero.watchSentence', lang, { relay: relayHtml });

const countdownLabel = t('hero.countdownLabel', lang);
const countdownDays = t('hero.countdownDays', lang);
const countdownHours = t('hero.countdownHours', lang);
const countdownMins = t('hero.countdownMins', lang);
const countdownSecs = t('hero.countdownSecs', lang);
---

<section id="home" class="relative overflow-hidden flex items-center">
  <div class="spotlight-bg" aria-hidden="true">
    <div class="spotlight spotlight-1"></div>
    <div class="spotlight spotlight-2"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-24 lg:py-32 w-full">
    <div class="hero-grid">
      <div class="hero-copy">
        <h1 class="hero-title">
          <span class="gradient-text">
            {titleLines.map((line, i) => (
              <>
                {i > 0 && <br />}
                {line}
              </>
            ))}
          </span>
        </h1>
        <p class="hero-tagline">{tagline}</p>

        <div class="hero-actions">
          {
            socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="hero-btn"
                aria-label={link.label}
              >
                <iconify-icon icon={link.icon} width="20" height="20" aria-hidden="true" />
                <span>{link.label}</span>
              </a>
            ))
          }
        </div>
      </div>

      <div class="hero-cta">
        <p class="cta-headline" set:html={watchSentenceHtml} />
        <div
          id="hero-countdown"
          class="cta-countdown"
          data-start-date={eventData.startDate}
          data-schedule-url={SCHEDULE_URL}
          aria-label={countdownLabel}
          hidden
        >
          <p class="cd-label">{countdownLabel}</p>
          <div class="cd-grid">
            <div class="cd-unit">
              <span class="cd-value" data-cd="d">0</span>
              <span class="cd-key">{countdownDays}</span>
            </div>
            <div class="cd-unit">
              <span class="cd-value" data-cd="h">00</span>
              <span class="cd-key">{countdownHours}</span>
            </div>
            <div class="cd-unit">
              <span class="cd-value" data-cd="m">00</span>
              <span class="cd-key">{countdownMins}</span>
            </div>
            <div class="cd-unit">
              <span class="cd-value" data-cd="s">00</span>
              <span class="cd-key">{countdownSecs}</span>
            </div>
          </div>
        </div>
        <p class="cta-dates">{eventDates}</p>
        <a href={twitchUrl} class="cta-btn" target="_blank" rel="noopener noreferrer">
          <iconify-icon icon="simple-icons:twitch" width="22" height="22" aria-hidden="true"
          ></iconify-icon>
          <span>{watchCta}</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .spotlight-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .spotlight {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(40px);
  }
  .spotlight-1 {
    width: 90vw;
    height: 90vw;
    max-width: 900px;
    max-height: 900px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.12) 0%, transparent 65%);
    top: -10%;
    left: -10%;
  }
  .spotlight-2 {
    width: 70vw;
    height: 70vw;
    max-width: 700px;
    max-height: 700px;
    background: radial-gradient(circle, rgba(14, 165, 233, 0.1) 0%, transparent 65%);
    bottom: -20%;
    right: -10%;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
      gap: 4rem;
    }
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-title {
    font-family: 'Final F', 'Shippori Mincho', 'Inter', system-ui, sans-serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.05;
    margin: 0;
    /* Final F has only weight 400 — disable synthesis so the JA body weight bump
       doesn't faux-bold it. Shippori still uses its actual 700 file for kana. */
    font-synthesis-weight: none;
  }

  .hero-tagline {
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    color: var(--text-muted);
    max-width: 36rem;
    line-height: 1.5;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.65rem 1.1rem;
    border-radius: 0.5rem;
    border: 1px solid rgba(99, 102, 241, 0.35);
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }
  .hero-btn:hover {
    background: rgba(99, 102, 241, 0.12);
    border-color: rgb(99 102 241);
    transform: translateY(-2px);
  }
  .hero-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .hero-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.025);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  }
  .cta-headline {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--text);
    margin: 0;
  }
  .cta-event {
    color: #fde047;
  }
  [data-theme='light'] .cta-event {
    color: #a16207;
  }
  .cta-dates {
    font-size: 1.05rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    margin: 0 0 0.5rem;
  }
  .cta-countdown {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    width: 100%;
  }
  .cd-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-dimmer);
    margin: 0;
  }
  .cd-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }
  .cd-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.7rem 0.4rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 0.55rem;
    background: rgba(255, 255, 255, 0.025);
  }
  [data-theme='light'] .cd-unit {
    background: rgba(0, 0, 0, 0.025);
  }
  .cd-value {
    font-size: clamp(1.5rem, 3.4vw, 2.1rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    color: #fde047;
  }
  [data-theme='light'] .cd-value {
    color: #a16207;
  }
  .cd-key {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dimmer);
    margin-top: 0.4rem;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.85rem 1.6rem;
    border-radius: 0.6rem;
    background: #9146ff;
    color: #ffffff;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition:
      background 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }
  .cta-btn:hover {
    background: #7c2cf3;
    transform: translateY(-2px);
    box-shadow: 0 12px 24px rgba(145, 70, 255, 0.35);
  }
  .cta-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
</style>

<script>
  import { parseCsv, parseUtcDayTime } from '../lib/sheetParse';

  const cdEl = document.getElementById('hero-countdown');
  if (cdEl) {
    const startDate = cdEl.dataset.startDate ?? '';
    const scheduleUrl = cdEl.dataset.scheduleUrl ?? '';
    const [y, m, d] = startDate.split('-').map(Number);
    // Provisional — refined to the schedule's first-run time on fetch.
    let targetMs = Date.UTC(y, m - 1, d);
    const dEl = cdEl.querySelector('[data-cd="d"]') as HTMLElement | null;
    const hEl = cdEl.querySelector('[data-cd="h"]') as HTMLElement | null;
    const mEl = cdEl.querySelector('[data-cd="m"]') as HTMLElement | null;
    const sEl = cdEl.querySelector('[data-cd="s"]') as HTMLElement | null;

    function pad(n: number) {
      return String(n).padStart(2, '0');
    }

    function tick(): boolean {
      const diff = targetMs - Date.now();
      if (diff <= 0) {
        cdEl!.hidden = true;
        return false;
      }
      const totalSecs = Math.floor(diff / 1000);
      if (dEl) dEl.textContent = String(Math.floor(totalSecs / 86_400));
      if (hEl) hEl.textContent = pad(Math.floor((totalSecs % 86_400) / 3600));
      if (mEl) mEl.textContent = pad(Math.floor((totalSecs % 3600) / 60));
      if (sEl) sEl.textContent = pad(totalSecs % 60);
      return true;
    }

    function findFirstStartTime(csv: string): Date | null {
      const rows = parseCsv(csv);
      const headerIdx = rows.findIndex((r) => /^game$/i.test((r[0] ?? '').trim()));
      if (headerIdx === -1) return null;
      const header = rows[headerIdx];
      const startCol = header.findIndex((h) => /start.*utc/i.test((h ?? '').trim()));
      if (startCol === -1) return null;
      for (let r = headerIdx + 1; r < rows.length; r++) {
        const name = (rows[r][0] ?? '').trim();
        if (!name) continue;
        const parsed = parseUtcDayTime(rows[r][startCol], startDate);
        if (parsed) return parsed;
      }
      return null;
    }

    async function refineTarget() {
      if (!scheduleUrl) return;
      try {
        const res = await fetch(scheduleUrl, { cache: 'no-store' });
        if (!res.ok) return;
        const t = findFirstStartTime(await res.text());
        if (t) targetMs = t.getTime();
      } catch {
        // Keep the midnight-UTC fallback.
      }
    }

    if (tick()) {
      cdEl.hidden = false;
      const handle = setInterval(() => {
        if (!tick()) clearInterval(handle);
      }, 1000);
      refineTarget();
    }
  }
</script>
