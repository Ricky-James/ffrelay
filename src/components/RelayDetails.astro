---
import Table, { type Column, type Cell, type CellTone, type FooterCell } from './Table.astro';
import data from '../data/relays.json';
import { localeFromAstro, localizedPath, t, tCompoundName, tTeamName, type Locale } from '../lib/i18n';

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? localeFromAstro(Astro);

type Relay = (typeof data.relays)[number];

const relays: Relay[] = data.relays;
const defaultIdx = relays.length - 1;

const TEAM_TONE: Record<string, CellTone> = {
  Mog: 'blue',
  Choco: 'yellow',
  Tonberry: 'green',
};

const colGameLabel = t('pastResults.colRelayGame', lang);
const colRunnerLabel = t('pastResults.colRelayRunner', lang);
const colTimeLabel = t('pastResults.colRelayTime', lang);
const relayPrefix = t('pastResults.tabRelayPrefix', lang);
const finalTimeLabel = t('pastResults.finalTime', lang);

function columnsForRelay(r: Relay): Column[] {
  return [
    { key: 'game', label: colGameLabel },
    ...r.teams.flatMap((team): Column[] => {
      const tone = TEAM_TONE[team];
      // Column keys stay English (data lookup keys); only the visible group label localizes.
      const groupLabel = tTeamName(team, lang);
      return [
        { key: `${team}-runner`, label: colRunnerLabel, group: groupLabel, tone },
        { key: `${team}-time`, label: colTimeLabel, align: 'center', group: groupLabel, tone },
      ];
    }),
  ];
}

function rowsForRelay(r: Relay): Array<Record<string, Cell>> {
  return r.games.map((g) => {
    const row: Record<string, Cell> = { game: tCompoundName(g.name, lang) };
    for (const run of g.runs) {
      row[`${run.team}-runner`] = run.runner;
      row[`${run.team}-time`] = run.time;
    }
    return row;
  });
}

// Each team's total spans the runner+time pair so it centers under the team header.
// Winner gets a TagCell for the colored glow.
function footerForRelay(r: Relay): FooterCell[] {
  return [
    { value: finalTimeLabel },
    ...r.teams.map((team): FooterCell => {
      const total = r.totals[team as keyof typeof r.totals] ?? '';
      const isWinner = team === r.winner;
      const tone = TEAM_TONE[team];
      return {
        colspan: 2,
        align: 'center',
        value: isWinner && tone && total ? { tag: total, tone } : total,
      };
    }),
  ];
}

const historyHref = localizedPath('/history', lang);
---

<section id="past-results-detail" class="section-pad">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
    <h3 class="section-heading">{t('pastResults.detailHeading', lang)}</h3>
    <p class="section-lead">
      {t('pastResults.detailLead', lang)}
      <br />
      {t('pastResults.detailFollowup', lang)} <a href={historyHref}>{t('pastResults.historyLinkText', lang)}</a> {t('pastResults.detailFollowupSuffix', lang)}
    </p>
    <div class="tablist" role="tablist" aria-label={t('pastResults.tabsAriaLabel', lang)}>
      {
        relays.map((r, i) => (
          <button
            type="button"
            class:list={['tab', i === defaultIdx && 'is-active']}
            role="tab"
            id={`tab-relay-${r.id}`}
            data-tab={r.id}
            aria-controls={`panel-relay-${r.id}`}
            aria-selected={i === defaultIdx ? 'true' : 'false'}
            tabindex={i === defaultIdx ? 0 : -1}
          >
            {relayPrefix + " " + r.shortLabel}
          </button>
        ))
      }
    </div>
  </div>

  {
    relays.map((r, i) => (
      <div
        id={`panel-relay-${r.id}`}
        class="relay-panel"
        role="tabpanel"
        aria-labelledby={`tab-relay-${r.id}`}
        hidden={i !== defaultIdx}
      >
        <div class="relay-table-wrap">
          <Table columns={columnsForRelay(r)} rows={rowsForRelay(r)} footerRow={footerForRelay(r)} compact />
        </div>
      </div>
    ))
  }
</section>

<style>
  .section-pad {
    padding: 2rem 0 6rem;
  }
  .section-heading {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .section-lead {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 50rem;
  }
  .section-lead a {
    color: #fbbf24;
    font-weight: 600;
    border-bottom: 1px dashed rgba(251, 191, 36, 0.45);
    transition:
      color 0.2s ease,
      border-bottom-color 0.2s ease,
      text-shadow 0.2s ease;
  }
  .section-lead a:hover {
    color: #fde047;
    border-bottom-color: #fde047;
    text-shadow: 0 0 10px rgba(253, 224, 71, 0.45);
  }
  .section-lead a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
  [data-theme='light'] .section-lead a {
    color: #a16207;
    border-bottom-color: rgba(161, 98, 7, 0.5);
  }
  [data-theme='light'] .section-lead a:hover {
    color: #713f12;
    border-bottom-color: #713f12;
    text-shadow: none;
  }

  .tablist {
    display: flex;
    flex-wrap: wrap;
    gap: 0.15rem;
    padding: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .tab {
    appearance: none;
    background: transparent;
    border: 1px solid transparent;
    border-bottom: 0;
    color: var(--text-dim);
    font: inherit;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.55rem 0.65rem;
    border-radius: 0.55rem 0.55rem 0 0;
    cursor: pointer;
    margin-bottom: -1px;
    transition:
      color 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease;
  }
  .tab:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.03);
  }
  .tab:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .tab.is-active {
    color: var(--text);
    background: var(--bg);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 1px 0 0 var(--bg);
  }
  [data-theme='light'] .tablist {
    border-bottom-color: rgba(0, 0, 0, 0.1);
  }
  [data-theme='light'] .tab.is-active {
    border-color: rgba(0, 0, 0, 0.1);
  }

  .relay-panel[hidden] {
    display: none;
  }

  .relay-table-wrap {
    width: calc(100vw - 2rem);
    margin-left: calc(50% - 50vw + 1rem);
    padding: 0 1rem;
    margin-bottom: 1.25rem;
  }
  @media (min-width: 1280px) {
    .relay-table-wrap {
      width: min(100vw - 4rem, 1600px);
      margin-left: 50%;
      transform: translateX(-50%);
      padding: 0;
    }
  }

</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tablist .tab');
  const panels = document.querySelectorAll<HTMLElement>('.relay-panel');

  function activate(id: string): boolean {
    let matched = false;
    tabs.forEach((t) => {
      const isActive = t.dataset.tab === id;
      if (isActive) matched = true;
      t.classList.toggle('is-active', isActive);
      t.setAttribute('aria-selected', isActive ? 'true' : 'false');
      t.tabIndex = isActive ? 0 : -1;
    });
    if (!matched) return false;
    panels.forEach((p) => {
      p.hidden = p.id !== `panel-relay-${id}`;
    });
    return true;
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const id = tab.dataset.tab;
      if (id && activate(id)) history.replaceState(null, '', `#relay-${id}`);
    });
  });

  document.querySelector('.tablist')?.addEventListener('keydown', (e) => {
    const evt = e as KeyboardEvent;
    if (evt.key !== 'ArrowLeft' && evt.key !== 'ArrowRight') return;
    const order = Array.from(tabs);
    const current = order.findIndex((t) => t === document.activeElement);
    if (current === -1) return;
    const next = (current + (evt.key === 'ArrowRight' ? 1 : -1) + order.length) % order.length;
    order[next].focus();
    order[next].click();
    evt.preventDefault();
  });

  const initial = window.location.hash.match(/^#relay-(.+)$/)?.[1];
  if (initial) activate(initial);
</script>
