---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import PastEvents from './PastEvents.astro';
import eventData from '../data/event.json';
import { localeFromAstro, t, tField, type Locale } from '../lib/i18n';

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? localeFromAstro(Astro);

const localizedEventName = tField(eventData, 'name', lang);
const title = `${t('pastResults.metaTitle', lang)} | ${localizedEventName}`;
const description = t('pastResults.metaDescription', lang, { eventName: localizedEventName });
---

<Layout title={title} description={description}>
  <Header />
    <PastEvents />
  <Footer />
</Layout>
