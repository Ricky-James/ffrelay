---
import Table, { type Column, type Cell } from './Table.astro';
import data from '../data/games.json';
import { localeFromAstro, t, tGameName, type Locale } from '../lib/i18n';

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? localeFromAstro(Astro);

const relayShortLabels: Record<string, string> = {
  'Relay I': 'I',
  'Relay II': 'II',
  'Relay III': 'III',
  'Relay IV': 'IV',
  'IV: Interlude': 'IV-I',
  'Relay V': 'V',
  'Relay VI': 'VI',
  'Relay VII': 'VII',
  'Relay VIII': 'VIII',
  'Relay IX': 'IX',
  'Relay X': 'X',
};

const groupRelaysLabel = t('games.groupRelays', lang);
const colGameLabel = t('games.colGame', lang);
const colTotalLabel = t('games.colTotalAppearances', lang);

const columns: Column[] = [
  { key: 'name', label: colGameLabel },
  ...data.relays.map((r) => ({
    key: `relay-${r}`,
    label: relayShortLabels[r] ?? r,
    align: 'center' as const,
    group: groupRelaysLabel,
  })),
  { key: 'total', label: colTotalLabel, align: 'center' as const },
];

const rows = data.games.map((g) => {
  const row: Record<string, Cell> = { name: tGameName(g.name, lang), total: g.total };
  g.platforms.forEach((p, i) => {
    row[`relay-${data.relays[i]}`] = p;
  });
  return row;
});
---

<div class="games-block">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
    <p class="section-lead">{t('games.lead', lang)}</p>
    <p class="game-count">{t('games.count', lang, { n: data.games.length })}</p>
  </div>
  <div class="games-table-wrap">
    <Table columns={columns} rows={rows} compact />
  </div>
</div>

<style>
  .section-lead {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
    max-width: 50rem;
  }
  .game-count {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
    font-variant-numeric: tabular-nums;
  }

  /* Break out of the page's max-width so the wide matrix has room to breathe. */
  .games-table-wrap {
    width: calc(100vw - 2rem);
    margin-left: calc(50% - 50vw + 1rem);
    padding: 0 1rem;
  }
  @media (min-width: 1280px) {
    .games-table-wrap {
      width: min(100vw - 4rem, 1600px);
      margin-left: 50%;
      transform: translateX(-50%);
      padding: 0;
    }
  }
</style>
