---
import Table, { type Column, type Cell } from './Table.astro';
import data from '../data/games.json';

const relayShortLabels: Record<string, string> = {
  'Relay I': 'I',
  'Relay II': 'II',
  'Relay III': 'III',
  'Relay IV': 'IV',
  'IV: Interlude': 'IV½',
  'Relay V': 'V',
  'Relay VI': 'VI',
  'Relay VII': 'VII',
  'Relay VIII': 'VIII',
  'Relay IX': 'IX',
  'Relay X': 'X',
};

const columns: Column[] = [
  { key: 'name', label: 'Game' },
  ...data.relays.map((r) => ({
    key: `relay-${r}`,
    label: relayShortLabels[r] ?? r,
    align: 'center' as const,
    group: 'Relays',
  })),
  { key: 'total', label: 'Total\nAppearances', align: 'center' as const },
];

const rows = data.games.map((g) => {
  const row: Record<string, Cell> = { name: g.name, total: g.total };
  g.platforms.forEach((p, i) => {
    row[`relay-${data.relays[i]}`] = p;
  });
  return row;
});
---

<div class="games-block">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
    <p class="section-lead">
      Every Final Fantasy title that has been part of a Relay Race, the version played in each
      relay, and how many times the game has been featured overall.
    </p>
    <p class="game-count">{data.games.length} games</p>
  </div>
  <div class="games-table-wrap">
    <Table columns={columns} rows={rows} compact />
  </div>
</div>

<style>
  .section-lead {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
    max-width: 50rem;
  }
  .game-count {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
    font-variant-numeric: tabular-nums;
  }

  /* Break out of the page's max-width so the wide matrix has room to breathe. */
  .games-table-wrap {
    width: calc(100vw - 2rem);
    margin-left: calc(50% - 50vw + 1rem);
    padding: 0 1rem;
  }
  @media (min-width: 1280px) {
    .games-table-wrap {
      width: min(100vw - 4rem, 1600px);
      margin-left: 50%;
      transform: translateX(-50%);
      padding: 0;
    }
  }
</style>
