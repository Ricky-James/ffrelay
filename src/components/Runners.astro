---
import Table, { type Column, type Cell } from './Table.astro';
import data from '../data/runners.json';
import { localeFromAstro, t, tGameName, type Locale } from '../lib/i18n';

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? localeFromAstro(Astro);

const relayShortLabels: Record<string, string> = {
  'Relay I': 'I',
  'Relay II': 'II',
  'Relay III': 'III',
  'Relay IV': 'IV',
  'IV: Interlude': 'IV-I',
  'Relay V': 'V',
  'Relay VI': 'VI',
  'Relay VII': 'VII',
  'Relay VIII': 'VIII',
  'Relay IX': 'IX',
  'Relay X': 'X',
};

const groupRelaysLabel = t('runners.groupRelays', lang);
const colRunnerLabel = t('runners.colRunner', lang);
const colTotalLabel = t('runners.colTotalAppearances', lang);

const columns: Column[] = [
  { key: 'name', label: colRunnerLabel },
  ...data.relays.map((r) => ({
    key: `relay-${r}`,
    label: relayShortLabels[r] ?? r,
    align: 'center' as const,
    group: groupRelaysLabel,
  })),
  { key: 'runs', label: colTotalLabel, align: 'center' },
];

// Runner handles are proper nouns — never translated. Only per-relay game cells localize.
const rows = data.runners.map((r) => {
  const row: Record<string, Cell> = { name: r.name, runs: r.runs };
  r.games.forEach((g, i) => {
    row[`relay-${data.relays[i]}`] = g ? tGameName(g, lang) : g;
  });
  return row;
});
---

<div class="runners-block">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
    <p class="section-lead">{t('runners.lead', lang)}</p>
    <p class="runner-count">{t('runners.count', lang, { n: data.runners.length })}</p>
  </div>
  <div class="runners-table-wrap">
    <Table columns={columns} rows={rows} compact />
  </div>
</div>

<style>
  .section-lead {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
    max-width: 50rem;
  }
  .runner-count {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
    font-variant-numeric: tabular-nums;
  }

  .runners-table-wrap {
    width: calc(100vw - 2rem);
    margin-left: calc(50% - 50vw + 1rem);
    padding: 0 1rem;
  }
  @media (min-width: 1280px) {
    .runners-table-wrap {
      width: min(100vw - 4rem, 1600px);
      margin-left: 50%;
      transform: translateX(-50%);
      padding: 0;
    }
  }
</style>
