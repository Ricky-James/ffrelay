---
import eventData from '../data/event.json';
import { csvExportUrl } from '../lib/sheetUrl';
import ProgressChart from './ProgressChart.astro';
import {
  buildGameNameMap,
  localeFromAstro,
  t,
  type Locale,
} from '../lib/i18n';

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? localeFromAstro(Astro);

const SPLITS_URL = csvExportUrl(eventData.sheet.sheetId, eventData.sheet.tabs.splits);
const INFO_URL = csvExportUrl(eventData.sheet.sheetId, eventData.sheet.tabs.info);
const POLL_MS = 30_000;
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const ariaLabel = t('liveStatus.ariaLabel', lang);
const onCommentaryLabel = t('liveStatus.onCommentary', lang);
const upNextLabel = t('liveStatus.upNext', lang);
const chartCaption = t('liveStatus.chartCaption', lang);
const tabRaceLabel = t('liveStatus.tabRace', lang);
const tabPerGameLabel = t('liveStatus.tabPerGame', lang);
const tabsHeading = t('liveStatus.tabsHeading', lang);
const gameSelectAriaLabel = t('liveStatus.gameSelectAriaLabel', lang);

const STRINGS_JSON = JSON.stringify({
  completionTimeLabel: t('liveStatus.completionTimeLabel', lang),
  gapFromOrdinalLabel: t('liveStatus.gapFromOrdinalLabel', lang),
  gapFromFirstLabel: t('liveStatus.gapFromFirstLabel', lang),
  runner: t('liveStatus.runner', lang),
  game: t('liveStatus.game', lang),
});
const NAME_MAP_JSON = JSON.stringify(buildGameNameMap(lang));
---

<section
  id="live-status"
  class="live-status"
  hidden
  aria-label={ariaLabel}
  data-splits-url={SPLITS_URL}
  data-info-url={INFO_URL}
  data-poll-ms={POLL_MS}
  data-base={BASE}
  data-locale={lang}
  data-name-map={NAME_MAP_JSON}
  data-strings={STRINGS_JSON}
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="ls-grid">
      <div class="ls-card">
        <div class="ls-controls-block">
          <p id="ls-view-controls-heading" class="ls-view-controls-heading">
            <iconify-icon
              icon="mdi:tune-variant"
              width="18"
              height="18"
              aria-hidden="true"
            ></iconify-icon>
            <span>{tabsHeading}</span>
          </p>
          <div class="ls-view-controls">
            <div class="ls-tabs" role="tablist" aria-labelledby="ls-view-controls-heading">
              <button
                type="button"
                class="ls-tab is-active"
                role="tab"
                data-mode="race"
                aria-selected="true"
              >
                {tabRaceLabel}
              </button>
              <button
                type="button"
                class="ls-tab"
                role="tab"
                data-mode="per-game"
                aria-selected="false"
              >
                {tabPerGameLabel}
              </button>
            </div>
            <div id="ls-pergame-select-wrap" class="ls-pergame-select-wrap" hidden>
              <select id="ls-pergame-select" aria-label={gameSelectAriaLabel}></select>
            </div>
          </div>
        </div>
        <div class="ls-standings">
          <ol id="ls-standings-list" class="ls-list"></ol>
        </div>

        <div id="ls-commentary-block" class="ls-commentary" hidden>
          <p class="ls-label">{onCommentaryLabel}</p>
          <ul id="ls-commentary-list" class="ls-comm-list"></ul>
        </div>

        <div id="ls-next-block" class="ls-upnext" hidden>
          <span class="ls-upnext-label">{upNextLabel}</span>
          <span class="ls-upnext-arrow" aria-hidden="true">→</span>
          <span id="ls-next" class="ls-upnext-game">—</span>
        </div>
      </div>

      <div class="ls-chart-col">
        <p class="ls-chart-caption">{chartCaption}</p>
        <ProgressChart />
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Global because the standings <li>s are inserted via innerHTML from the script
     below and would lose Astro's scoping attribute. All selectors are .ls-* prefixed
     to avoid leaking into the rest of the page. */
  .live-status {
    padding: 0 0 2rem;
  }
  .ls-grid {
    display: grid;
    grid-template-columns: minmax(320px, 420px) minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 1023px) {
    .ls-grid {
      grid-template-columns: 1fr;
    }
  }
  .ls-chart-col {
    min-width: 0;
  }
  .ls-chart-caption {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin: 0 0 0.6rem;
    line-height: 1.4;
  }
  .ls-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.025);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    padding: 1.5rem 1.75rem;
  }
  .ls-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(251, 191, 36, 0.45), transparent);
  }
  [data-theme='light'] .ls-card {
    background: rgba(255, 255, 255, 0.85);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.08);
  }
  [data-theme='light'] .ls-card::before {
    background: linear-gradient(90deg, transparent, rgba(202, 138, 4, 0.45), transparent);
  }

  .ls-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--text-dimmer);
    margin: 0 0 0.7rem;
  }

  .ls-controls-block {
    padding-bottom: 1.1rem;
    margin-bottom: 1.1rem;
    border-bottom: 1px solid var(--border);
  }
  .ls-view-controls-heading {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.005em;
    margin: 0 0 0.65rem;
  }
  .ls-view-controls-heading iconify-icon {
    color: #fde047;
    flex: none;
  }
  [data-theme='light'] .ls-view-controls-heading iconify-icon {
    color: #b45309;
  }
  .ls-view-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem 0.85rem;
  }

  .ls-tabs {
    display: inline-flex;
    padding: 3px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.04);
  }
  [data-theme='light'] .ls-tabs {
    border-color: rgba(0, 0, 0, 0.14);
    background: rgba(0, 0, 0, 0.03);
  }
  .ls-tab {
    appearance: none;
    border: none;
    background: transparent;
    color: var(--text);
    font-family: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.38rem 0.85rem;
    border-radius: 0.4rem;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .ls-tab:hover { background: rgba(255, 255, 255, 0.04); }
  [data-theme='light'] .ls-tab:hover { background: rgba(0, 0, 0, 0.04); }
  .ls-tab:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .ls-tab.is-active {
    background: rgba(251, 191, 36, 0.22);
    color: #fde047;
  }
  .ls-tab.is-active:hover {
    background: rgba(251, 191, 36, 0.22);
  }
  [data-theme='light'] .ls-tab.is-active {
    background: #b45309;
    color: #ffffff;
  }
  [data-theme='light'] .ls-tab.is-active:hover {
    color: #ffffff;
  }
  .ls-pergame-select-wrap {
    margin: 0;
    min-width: 14rem;
    max-width: 24rem;
    flex: 0 1 auto;
  }
  #ls-pergame-select {
    appearance: none;
    color-scheme: dark;
    background-color: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 0.4rem;
    color: var(--text);
    font: inherit;
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    padding: 0.4rem 1.9rem 0.4rem 0.7rem;
    cursor: pointer;
    background-image: linear-gradient(45deg, transparent 50%, var(--text-muted) 50%),
                      linear-gradient(135deg, var(--text-muted) 50%, transparent 50%);
    background-position: right 0.85rem center, right 0.55rem center;
    background-size: 5px 5px, 5px 5px;
    background-repeat: no-repeat;
    width: 100%;
  }
  #ls-pergame-select option {
    background-color: #0f172a;
    color: #e2e8f0;
  }
  [data-theme='light'] #ls-pergame-select {
    color-scheme: light;
    background-color: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.18);
  }
  [data-theme='light'] #ls-pergame-select option {
    background-color: #ffffff;
    color: #1e293b;
  }
  #ls-pergame-select:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .ls-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    font-variant-numeric: tabular-nums;
  }
  .ls-row {
    display: grid;
    grid-template-columns: 2.4rem minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.95rem;
    padding: 0.65rem 0.95rem;
    border-radius: 0.65rem;
    background: rgba(255, 255, 255, 0.018);
    border: 1px solid var(--border);
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  /* Icon is a CSS mask so we can recolour without baking colours into the SVG files. */
  .ls-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
  }
  .ls-icon::after {
    content: '';
    display: block;
    width: 1.35rem;
    height: 1.35rem;
    background-color: var(--text-muted);
    -webkit-mask: var(--ls-icon-url) center / contain no-repeat;
            mask: var(--ls-icon-url) center / contain no-repeat;
  }
  [data-theme='light'] .ls-icon {
    background: rgba(0, 0, 0, 0.025);
  }
  .ls-row.tone-blue .ls-icon::after   { background-color: #38bdf8; }
  .ls-row.tone-yellow .ls-icon::after { background-color: #fde047; }
  .ls-row.tone-green .ls-icon::after  { background-color: #4ade80; }
  [data-theme='light'] .ls-row.tone-blue .ls-icon::after   { background-color: #0c4a6e; }
  [data-theme='light'] .ls-row.tone-yellow .ls-icon::after { background-color: #713f12; }
  [data-theme='light'] .ls-row.tone-green .ls-icon::after  { background-color: #14532d; }
  .ls-team-block {
    display: flex;
    flex-direction: column;
    min-width: 0;
    gap: 0.1rem;
  }
  .ls-team {
    font-size: 1.05rem;
    font-weight: 600;
    /* Inherit team colour from the row's tone class; leader rule adds weight + glow. */
    color: inherit;
    letter-spacing: -0.01em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ls-meta {
    font-size: 0.78rem;
    color: var(--text-dim);
    letter-spacing: 0.02em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ls-meta-label {
    color: var(--text-dimmer);
    margin-right: 0.3rem;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .ls-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, currentColor 30%, transparent);
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s ease;
  }
  .ls-link:hover {
    text-decoration-color: currentColor;
  }
  .ls-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
  /* Medal palette (gold/silver/bronze) — kept distinct from team tones. */
  .ls-rank {
    display: inline-flex;
    align-items: baseline;
    gap: 0.05rem;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .ls-rank-num {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.04em;
  }
  .ls-rank-ord {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.75;
  }
  .ls-rank-1 {
    color: #fde047;
    text-shadow: 0 0 18px rgba(253, 224, 71, 0.45);
  }
  .ls-rank-2 {
    color: #cbd5e1;
    text-shadow: 0 0 14px rgba(203, 213, 225, 0.3);
  }
  .ls-rank-3 {
    color: #d4946e;
    text-shadow: 0 0 14px rgba(212, 148, 110, 0.3);
  }
  [data-theme='light'] .ls-rank-1 {
    color: #a16207;
    text-shadow: none;
  }
  [data-theme='light'] .ls-rank-2 {
    color: #475569;
    text-shadow: none;
  }
  [data-theme='light'] .ls-rank-3 {
    color: #9a3412;
    text-shadow: none;
  }

  .ls-row.is-leader {
    background: color-mix(in srgb, currentColor 9%, transparent);
    border-color: color-mix(in srgb, currentColor 38%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, currentColor 18%, transparent) inset,
                0 8px 24px color-mix(in srgb, currentColor 14%, transparent);
  }
  .ls-row.is-leader .ls-icon {
    background: currentColor;
    border-color: transparent;
    box-shadow: 0 0 14px color-mix(in srgb, currentColor 55%, transparent);
  }
  .ls-row.is-leader .ls-icon::after {
    background-color: var(--bg);
  }
  .ls-row.is-leader .ls-team {
    font-weight: 700;
    text-shadow: 0 0 14px color-mix(in srgb, currentColor 45%, transparent);
  }
  .ls-row.is-leader .ls-meta {
    color: color-mix(in srgb, currentColor 75%, var(--text));
  }
  .ls-row.is-leader .ls-meta-label {
    color: color-mix(in srgb, currentColor 55%, transparent);
  }

  .ls-row.tone-blue       { color: #38bdf8; }
  .ls-row.tone-yellow     { color: #fde047; }
  .ls-row.tone-green      { color: #4ade80; }
  [data-theme='light'] .ls-row.tone-blue   { color: #0c4a6e; }
  [data-theme='light'] .ls-row.tone-yellow { color: #713f12; }
  [data-theme='light'] .ls-row.tone-green  { color: #14532d; }


  .ls-commentary {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }
  .ls-comm-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .ls-comm-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.35;
  }
  .ls-comm-game {
    color: var(--text);
    font-weight: 700;
    letter-spacing: -0.005em;
  }
  .ls-comm-people {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .ls-upnext {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .ls-upnext-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-dimmer);
  }
  .ls-upnext-arrow {
    color: var(--text-dimmer);
    font-size: 0.9rem;
    line-height: 1;
  }
  .ls-upnext-game {
    color: var(--text);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: -0.005em;
  }
</style>

<script>
  // @ts-nocheck
  import {
    parseCsv,
    timeToSeconds,
    teamSlug,
    escapeHtml,
    gameKey,
    parseInfo,
    linkName as linkNameLib,
  } from '../lib/sheetParse';
  import { fillTemplate, makeTranslator, readDataJson, tTeamName } from '../lib/clientI18n';

  const TEAM_TONE = { mog: 'blue', choco: 'yellow', tonberry: 'green' };
  const ICON_TEAMS = new Set(['mog', 'choco', 'tonberry']);
  const sectionEl = document.getElementById('live-status');
  const standingsEl = document.getElementById('ls-standings-list');
  const nextEl = document.getElementById('ls-next');
  const nextBlockEl = document.getElementById('ls-next-block');
  const commBlockEl = document.getElementById('ls-commentary-block');
  const commListEl = document.getElementById('ls-commentary-list');
  const tabElsLs = Array.from(sectionEl.querySelectorAll('.ls-tab'));
  const pergameSelectEl = document.getElementById('ls-pergame-select');
  const pergameSelectWrapEl = document.getElementById('ls-pergame-select-wrap');

  const SPLITS_URL = sectionEl.dataset.splitsUrl;
  const INFO_URL = sectionEl.dataset.infoUrl;
  const POLL_MS = Number(sectionEl.dataset.pollMs) || 30_000;
  const BASE = sectionEl.dataset.base;
  const LOCALE = sectionEl.dataset.locale || 'en';
  const STRINGS = readDataJson(sectionEl, 'strings');
  const tGame = makeTranslator(readDataJson(sectionEl, 'nameMap'));

  let pollHandle = null;
  let standingsMode = 'race';     // 'race' | 'per-game'
  let selectedStandingsGame = null;  // raw game name to display in per-game mode
  let lastParsedSplits = null;
  let lastInfo = null;

  // Idempotent so the 30s poll doesn't churn the chart on unchanged state.
  let lastBroadcastedMode;
  let lastBroadcastedGame;
  function broadcastViewState() {
    if (standingsMode === lastBroadcastedMode && selectedStandingsGame === lastBroadcastedGame) return;
    lastBroadcastedMode = standingsMode;
    lastBroadcastedGame = selectedStandingsGame;
    document.dispatchEvent(new CustomEvent('ffrelay:view-state', {
      detail: { mode: standingsMode, game: selectedStandingsGame },
    }));
  }

  const linkName = (p) => linkNameLib(p, 'ls-link');

  // English uses 1st/2nd/3rd/…; Japanese uses 1位/2位/3位/….
  function ordinal(n) {
    if (LOCALE === 'ja') return `${n}位`;
    const v = n % 100;
    if (v >= 11 && v <= 13) return `${n}th`;
    return `${n}${['th', 'st', 'nd', 'rd'][n % 10] || 'th'}`;
  }

  function formatHMS(secs) {
    const total = Math.max(0, Math.round(secs));
    const h = Math.floor(total / 3600);
    const m = String(Math.floor((total % 3600) / 60)).padStart(2, '0');
    const s = String(total % 60).padStart(2, '0');
    return `${h}:${m}:${s}`;
  }

  function formatGap(secs) {
    const total = Math.max(0, Math.round(secs));
    const h = Math.floor(total / 3600);
    const m = Math.floor((total % 3600) / 60);
    const s = String(total % 60).padStart(2, '0');
    if (h > 0) return `+${h}:${String(m).padStart(2, '0')}:${s}`;
    return `+${m}:${s}`;
  }

  function parseSplits(text) {
    const rows = parseCsv(text);
    const headerIdx = rows.findIndex((r) => /^split name/i.test((r[0] ?? '').trim()));
    if (headerIdx === -1) return null;
    const labelRow = rows[headerIdx];

    const cols = [];
    for (let i = 1; i < labelRow.length; i++) {
      const v = (labelRow[i] ?? '').trim();
      const m = v.match(/^team\s+(.+)$/i);
      if (m) cols.push({ col: i, team: teamSlug(m[1]), display: m[1].trim() });
      else if (cols.length > 0) break;
    }
    if (cols.length === 0) return null;

    const splits = [];
    for (let r = headerIdx + 1; r < rows.length; r++) {
      const row = rows[r];
      const name = (row[0] ?? '').trim();
      if (!name) continue;
      const times = {};
      for (const c of cols) {
        times[c.team] = timeToSeconds((row[c.col] ?? '').trim());
      }
      splits.push({ name, times, isGameEnd: /\bfinal fantasy\b/i.test(name) });
    }

    return { teams: cols, splits };
  }

  function computeStatus(parsed, info) {
    const { teams, splits } = parsed;
    const games = splits.filter((s) => s.isGameEnd);
    if (games.length === 0) return null;

    // Split-level progress drives ranking (a team a single split ahead ranks above one that isn't).
    const lastDoneSplitIdx = {};
    for (const t of teams) {
      let idx = -1;
      for (let i = 0; i < splits.length; i++) {
        if (splits[i].times[t.team] != null) idx = i;
      }
      lastDoneSplitIdx[t.team] = idx;
    }
    if (Object.values(lastDoneSplitIdx).every((i) => i < 0)) return null;

    const lastDoneGameIdx = {};
    for (const t of teams) {
      let idx = -1;
      for (let i = 0; i < games.length; i++) {
        if (games[i].times[t.team] != null) idx = i;
      }
      lastDoneGameIdx[t.team] = idx;
    }

    const standings = teams.map((t) => {
      const splitProgress = lastDoneSplitIdx[t.team];
      return {
        team: t.team,
        display: t.display,
        splitProgress,
        gameProgress: lastDoneGameIdx[t.team],
        ownSecs: splitProgress >= 0 ? splits[splitProgress].times[t.team] : null,
      };
    }).sort((a, b) => {
      if (b.splitProgress !== a.splitProgress) return b.splitProgress - a.splitProgress;
      if (a.ownSecs == null) return 1;
      if (b.ownSecs == null) return -1;
      return a.ownSecs - b.ownSecs;
    });

    const leader = standings[0];

    const currentGameByTeam = {};
    for (const t of teams) {
      const idx = lastDoneGameIdx[t.team] + 1;
      currentGameByTeam[t.team] = idx < games.length ? games[idx] : null;
    }

    const finalIdx = games.length - 1;
    for (const s of standings) {
      const current = currentGameByTeam[s.team];
      s.game = current?.name ?? null;
      const entry = info && current ? info.get(gameKey(current.name)) : null;
      s.runner = entry?.runners.find((r) => r.team === s.team) ?? null;
      s.finishedSecs = s.gameProgress === finalIdx && finalIdx >= 0
        ? games[finalIdx].times[s.team] ?? null
        : null;
    }

    // Final time deltas for finished teams. Anyone ranked above a finished team
    // must also be finished (more progress wins on splitProgress), so these are
    // always well-defined for non-leader finishers.
    for (let i = 0; i < standings.length; i++) {
      const s = standings[i];
      if (s.finishedSecs == null) continue;
      s.finishGapToLeader = i > 0 ? s.finishedSecs - standings[0].finishedSecs : null;
      s.finishGapToPrev   = i > 1 ? s.finishedSecs - standings[i - 1].finishedSecs : null;
    }

    // Two-part gap: race-time delta at our last common split, AND the leader's
    // wall-clock advance from any extra splits they've done since. Taking the max
    // avoids showing +0:00 when we tied at the common point but the leader has
    // since pulled ahead by completing more splits. Teams ranked above always
    // have splitProgress >= mine (sort order), so lookups at my split are safe.
    for (let i = 0; i < standings.length; i++) {
      const s = standings[i];
      if (s.finishedSecs != null) continue;
      if (s.splitProgress < 0 || s.ownSecs == null) continue;
      if (i > 0) {
        const leader = standings[0];
        const leaderAtMine = splits[s.splitProgress].times[leader.team];
        if (leaderAtMine != null) {
          const gapAtCommon = s.ownSecs - leaderAtMine;
          const gapByProgress = leader.ownSecs != null ? leader.ownSecs - s.ownSecs : -Infinity;
          s.liveGapToLeader = Math.max(gapAtCommon, gapByProgress);
        }
      }
      if (i > 1) {
        const prev = standings[i - 1];
        const prevAtMine = splits[s.splitProgress].times[prev.team];
        if (prevAtMine != null) {
          const gapAtCommon = s.ownSecs - prevAtMine;
          const gapByProgress = prev.ownSecs != null ? prev.ownSecs - s.ownSecs : -Infinity;
          s.liveGapToPrev = Math.max(gapAtCommon, gapByProgress);
        }
      }
    }

    const currentGames = [];
    const seenCurrent = new Set();
    for (const t of teams) {
      const g = currentGameByTeam[t.team];
      if (!g) continue;
      if (!seenCurrent.has(g.name)) {
        seenCurrent.add(g.name);
        currentGames.push(g.name);
      }
    }

    const commentary = [];
    if (info) {
      for (const name of currentGames) {
        const entry = info.get(gameKey(name));
        if (entry && entry.commentators.length) {
          commentary.push({ game: name, people: entry.commentators });
        }
      }
    }

    const leaderNextGameIdx = leader.gameProgress + 2;
    const nextGame = leaderNextGameIdx < games.length ? games[leaderNextGameIdx].name : null;

    return { standings, currentGames, nextGame, commentary };
  }

  // Falls back to the most recent game with data when targetGameName is
  // unset/unknown — keeps the panel populated with the just-finished game
  // when the current game has no splits yet.
  function computeStatusPerGame(parsed, info, targetGameName) {
    const { teams, splits } = parsed;

    const groups = [];
    let bucket = [];
    for (const s of splits) {
      bucket.push(s);
      if (s.isGameEnd) {
        groups.push({ name: s.name, rows: bucket });
        bucket = [];
      }
    }
    if (groups.length === 0) return null;

    let displayedIdx = targetGameName
      ? groups.findIndex((g) => g.name === targetGameName)
      : -1;
    if (displayedIdx === -1) {
      for (let i = groups.length - 1; i >= 0; i--) {
        if (groups[i].rows.some((r) => teams.some((t) => r.times[t.team] != null))) {
          displayedIdx = i; break;
        }
      }
    }
    if (displayedIdx === -1) return null;

    const group = groups[displayedIdx];

    // Per-team because cumulative ordering means a team with intra-game data
    // here necessarily finished the previous game — so the baseline exists.
    const baseline = {};
    for (const t of teams) baseline[t.team] = 0;
    if (displayedIdx > 0) {
      const prev = groups[displayedIdx - 1].rows[groups[displayedIdx - 1].rows.length - 1];
      for (const t of teams) {
        if (prev.times[t.team] != null) baseline[t.team] = prev.times[t.team];
      }
    }

    const finalIdx = group.rows.length - 1;
    const teamData = teams.map((t) => {
      let lastDoneIdx = -1;
      for (let i = 0; i < group.rows.length; i++) {
        if (group.rows[i].times[t.team] != null) lastDoneIdx = i;
      }
      const intraCumSecs = lastDoneIdx >= 0
        ? group.rows[lastDoneIdx].times[t.team] - baseline[t.team]
        : null;
      return {
        team: t.team,
        display: t.display,
        lastDoneIdx,
        intraCumSecs,
        finished: lastDoneIdx === finalIdx,
      };
    });

    const standings = teamData.sort((a, b) => {
      if (b.lastDoneIdx !== a.lastDoneIdx) return b.lastDoneIdx - a.lastDoneIdx;
      if (a.intraCumSecs == null) return 1;
      if (b.intraCumSecs == null) return -1;
      return a.intraCumSecs - b.intraCumSecs;
    });

    const entry = info ? info.get(gameKey(group.name)) : null;
    for (const s of standings) {
      s.game = group.name;
      s.runner = entry?.runners.find((r) => r.team === s.team) ?? null;
      s.finishedSecs = s.finished ? s.intraCumSecs : null;
    }

    // Individual Game intentionally omits From 1st / From 2nd deltas — the
    // race-wide standings carry that cross-team context already.

    const commentary = [];
    if (entry && entry.commentators.length) {
      commentary.push({ game: group.name, people: entry.commentators });
    }

    return { standings, currentGames: [group.name], nextGame: null, commentary, displayedGameName: group.name };
  }

  function render(status) {
    if (!status || status.standings.length === 0) {
      sectionEl.hidden = true;
      return;
    }
    sectionEl.hidden = false;

    const html = status.standings.map((row, i) => {
      const tone = TEAM_TONE[row.team] || '';
      const cls = ['ls-row'];
      if (tone) cls.push(`tone-${tone}`);
      if (i === 0) cls.push('is-leader');
      const iconSlug = ICON_TEAMS.has(row.team) ? row.team : null;
      const iconStyle = iconSlug
        ? `style="--ls-icon-url: url('${BASE}images/teams/${iconSlug}.svg')"`
        : '';
      let subtitleHtml = '';
      if (row.finishedSecs != null) {
        // Mirror the Runner/Game label+value pattern used in the active state below.
        const parts = [{
          label: STRINGS.completionTimeLabel,
          value: formatHMS(row.finishedSecs),
        }];
        if (row.finishGapToPrev != null) {
          parts.push({
            label: fillTemplate(STRINGS.gapFromOrdinalLabel, { ordinal: ordinal(i) }),
            value: formatGap(row.finishGapToPrev),
          });
        }
        if (row.finishGapToLeader != null) {
          parts.push({
            label: STRINGS.gapFromFirstLabel,
            value: formatGap(row.finishGapToLeader),
          });
        }
        subtitleHtml = parts.map(({ label, value }) =>
          `<span class="ls-meta"><span class="ls-meta-label">${escapeHtml(label)}</span>${escapeHtml(value)}</span>`,
        ).join('');
      } else {
        const runnerLine = row.runner
          ? `<span class="ls-meta"><span class="ls-meta-label">${escapeHtml(STRINGS.runner)}</span>${linkName(row.runner)}</span>`
          : '';
        const gameLine = row.game
          ? `<span class="ls-meta"><span class="ls-meta-label">${escapeHtml(STRINGS.game)}</span>${escapeHtml(tGame(row.game))}</span>`
          : '';
        const gapParts = [];
        if (row.liveGapToPrev != null) {
          gapParts.push({
            label: fillTemplate(STRINGS.gapFromOrdinalLabel, { ordinal: ordinal(i) }),
            value: formatGap(row.liveGapToPrev),
          });
        }
        if (row.liveGapToLeader != null) {
          gapParts.push({
            label: STRINGS.gapFromFirstLabel,
            value: formatGap(row.liveGapToLeader),
          });
        }
        const gapHtml = gapParts.map(({ label, value }) =>
          `<span class="ls-meta"><span class="ls-meta-label">${escapeHtml(label)}</span>${escapeHtml(value)}</span>`,
        ).join('');
        subtitleHtml = runnerLine + gameLine + gapHtml;
      }

      const place = i + 1;
      const rankHtml = `<span class="ls-rank ls-rank-${place}">`
        + `<span class="ls-rank-num">${place}</span>`
        + `<span class="ls-rank-ord">${escapeHtml(LOCALE === 'ja' ? '位' : (ordinal(place).replace(String(place), '')))}</span>`
        + `</span>`;

      return `<li class="${cls.join(' ')}">`
        + `<span class="ls-icon" ${iconStyle} aria-hidden="true"></span>`
        + `<span class="ls-team-block">`
        +   `<span class="ls-team">${escapeHtml(tTeamName(row.display, LOCALE))}</span>`
        +   subtitleHtml
        + `</span>`
        + rankHtml
        + '</li>';
    }).join('');
    standingsEl.innerHTML = html;

    if (status.nextGame) {
      nextBlockEl.hidden = false;
      nextEl.textContent = tGame(status.nextGame);
    } else {
      nextBlockEl.hidden = true;
    }

    if (status.commentary && status.commentary.length) {
      commBlockEl.hidden = false;
      commListEl.innerHTML = status.commentary.map((c) => (
        `<li class="ls-comm-item">`
        + `<span class="ls-comm-game">${escapeHtml(tGame(c.game))}</span>`
        + `<span class="ls-comm-people">${c.people.map(linkName).join(', ')}</span>`
        + '</li>'
      )).join('');
    } else {
      commBlockEl.hidden = true;
    }
  }

  function populatePergameSelect(names) {
    const existing = Array.from(pergameSelectEl.options).map((o) => o.value);
    if (existing.length === names.length && existing.every((v, i) => v === names[i])) return;
    pergameSelectEl.innerHTML = names
      .map((n) => `<option value="${escapeHtml(n)}">${escapeHtml(tGame(n))}</option>`)
      .join('');
    if (selectedStandingsGame && names.includes(selectedStandingsGame)) {
      pergameSelectEl.value = selectedStandingsGame;
    }
  }

  function ensureStandingsGame() {
    if (!lastParsedSplits) return;
    const groups = [];
    let bucket = [];
    for (const s of lastParsedSplits.splits) {
      bucket.push(s);
      if (s.isGameEnd) {
        groups.push({ name: s.name, rows: bucket });
        bucket = [];
      }
    }
    const started = groups.filter((g) =>
      g.rows.some((r) => lastParsedSplits.teams.some((t) => r.times[t.team] != null)),
    );
    const names = started.map((g) => g.name);
    populatePergameSelect(names);
    if (selectedStandingsGame && names.includes(selectedStandingsGame)) return;
    selectedStandingsGame = names.length > 0 ? names[names.length - 1] : null;
    if (selectedStandingsGame) pergameSelectEl.value = selectedStandingsGame;
  }

  function rerender() {
    if (!lastParsedSplits) {
      sectionEl.hidden = true;
      pergameSelectWrapEl.hidden = true;
      return;
    }
    ensureStandingsGame();
    const status = standingsMode === 'per-game'
      ? computeStatusPerGame(lastParsedSplits, lastInfo, selectedStandingsGame)
      : computeStatus(lastParsedSplits, lastInfo);
    render(status);
    broadcastViewState();
  }

  function setStandingsMode(next) {
    if (next === standingsMode) return;
    standingsMode = next;
    for (const t of tabElsLs) {
      const isActive = t.dataset.mode === standingsMode;
      t.classList.toggle('is-active', isActive);
      t.setAttribute('aria-selected', isActive ? 'true' : 'false');
    }
    pergameSelectWrapEl.hidden = standingsMode !== 'per-game';
    rerender();
  }
  for (const tab of tabElsLs) {
    tab.addEventListener('click', () => setStandingsMode(tab.dataset.mode));
  }
  pergameSelectEl.addEventListener('change', () => {
    selectedStandingsGame = pergameSelectEl.value;
    rerender();
  });

  async function refresh() {
    try {
      // Info is best-effort — if it fails the panel still renders standings without
      // runner subtitles or commentary.
      const bust = `&_=${Date.now()}&r=${Math.random().toString(36).slice(2)}`;
      const [splitsRes, infoRes] = await Promise.all([
        fetch(SPLITS_URL + bust, { cache: 'no-store' }),
        fetch(INFO_URL + bust, { cache: 'no-store' }).catch(() => null),
      ]);
      if (!splitsRes.ok) return;
      const parsed = parseSplits(await splitsRes.text());
      if (!parsed) {
        sectionEl.hidden = true;
        return;
      }
      let info = null;
      if (infoRes && infoRes.ok) {
        try { info = parseInfo(await infoRes.text()); } catch {}
      }
      lastParsedSplits = parsed;
      lastInfo = info;
      rerender();
    } catch {
      // Silent — keep showing the previous state rather than blanking.
    }
  }

  function start() {
    if (pollHandle != null) return;
    refresh();
    pollHandle = setInterval(refresh, POLL_MS);
  }
  function stop() {
    if (pollHandle != null) {
      clearInterval(pollHandle);
      pollHandle = null;
    }
  }

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) stop();
    else start();
  });

  start();
</script>
