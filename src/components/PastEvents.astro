---
import Table, { type Column, type Cell, type CellTone } from './Table.astro';
import RelayDetails from './RelayDetails.astro';
import data from '../data/past-events.json';
import { localeFromAstro, t, tTeamName, type Locale } from '../lib/i18n';

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? localeFromAstro(Astro);

const columns: Column[] = [
  { key: 'event', label: t('pastResults.colEvent', lang) },
  { key: 'date', label: t('pastResults.colDate', lang), align: 'center', width: '8rem' },
  { key: 'teams', label: t('pastResults.colTeams', lang), align: 'center', width: '5rem' },
  { key: 'winner', label: t('pastResults.colWinner', lang), align: 'center', width: '8rem' },
  { key: 'vod', label: t('pastResults.colVod', lang), align: 'center', width: '5rem' },
];

const dateFmt = new Intl.DateTimeFormat(lang === 'ja' ? 'ja-JP' : 'en-GB', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});

const TEAM_TONES: Record<string, CellTone> = {
  Mog: 'blue',
  Choco: 'yellow',
  Tonberry: 'green',
};

function winnerCell(name: string): Cell {
  if (!name) return '';
  const tone = TEAM_TONES[name];
  const display = tTeamName(name, lang);
  return tone ? { tag: display, tone } : display;
}

const vodLinkText = t('pastResults.vodLinkText', lang);
const relayPrefix = t('pastResults.tabRelayPrefix', lang);
const interludeLabel = t('pastResults.interludeSuffix', lang);

// EN keys default to the English value in en.json so EN renders unchanged.
function localizeEventName(name: string): string {
  return name
    .replace(/^Relay\b/, relayPrefix)
    .replace(/\bInterlude\b/, interludeLabel);
}

const rows = data.events.map((e) => {
  const row: Record<string, Cell> = {
    event: localizeEventName(e.event),
    date: e.date ? dateFmt.format(new Date(e.date)) : '',
    teams: e.teams,
    winner: winnerCell(e.winner),
    vod: e.vod ? { href: e.vod, text: vodLinkText } : '',
  };
  return row;
});

const rowTones = data.events.map((e) => TEAM_TONES[e.winner]);
---

<section id="previous-winners" class="section-pad">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
    <h2 class="section-heading">{t('pastResults.heading', lang)}</h2>
    <p class="section-lead">{t('pastResults.lead', lang)}</p>
    <Table columns={columns} rows={rows} rowTones={rowTones} />
  </div>
  <RelayDetails />
</section>

<style>
  .section-pad {
    padding: 6rem 0;
  }
  .section-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .section-lead {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 50rem;
  }
</style>
