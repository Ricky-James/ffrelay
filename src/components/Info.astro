---
import { localeFromAstro, t, type Locale } from '../lib/i18n';

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? localeFromAstro(Astro);
---

<section id="info" class="section-pad">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
    <p class="eyebrow">{t('info.eyebrow', lang)}</p>
    <h2 class="section-heading">{t('info.heading', lang)}</h2>

    <div class="info-body">
      <p>{t('info.paragraph1', lang)}</p>
      <p>{t('info.paragraph2', lang)}</p>
    </div>
  </div>
</section>

<style>
  .section-pad {
    padding: 6rem 0;
  }
  .eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }
  .section-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 2rem;
  }
  .info-body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-muted);
  }
</style>
