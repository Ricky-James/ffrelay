---
import '../styles/global.css';
import siteData from '../data/site.json';
import eventData from '../data/event.json';

interface Props {
  title?: string;
  description?: string;
}

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const { title = siteData.title, description = siteData.description } = Astro.props;

const siteOrigin = Astro.site?.origin ?? eventData.url;
const canonicalURL = `${siteOrigin}${Astro.url.pathname}`;

const sameAsLinks = [
  eventData.twitch && `https://twitch.tv/${eventData.twitch}`,
  eventData.youtube && `https://youtube.com/@${eventData.youtube}`,
].filter(Boolean) as string[];

const defaultSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Event",
      "@id": `${eventData.url}/#event`,
      name: eventData.name,
      description: eventData.tagline,
      url: eventData.url,
      eventStatus: "https://schema.org/EventScheduled",
      eventAttendanceMode: "https://schema.org/OnlineEventAttendanceMode",
      sameAs: sameAsLinks,
    },
    {
      "@type": "WebSite",
      "@id": `${eventData.url}/#website`,
      name: siteData.title,
      description: description,
      url: eventData.url,
    },
  ],
};

function safeJsonLd(obj: object): string {
  return JSON.stringify(obj).replace(/<\/script>/gi, "<\\/script>");
}
---

<!doctype html>
<html lang="en" style="color-scheme: dark; background: #020617;" data-theme-key={siteData.themeStorageKey}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content={eventData.name} />
    <meta name="application-name" content={siteData.ogSiteName} />
    <meta name="color-scheme" content="dark light" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type"         content="website" />
    <meta property="og:url"          content={canonicalURL} />
    <meta property="og:title"        content={title} />
    <meta property="og:description"  content={description} />
    <meta property="og:site_name"    content={siteData.ogSiteName} />
    <meta property="og:locale"       content="en_US" />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href={`${base}images/favicons/favicon.svg`} />
    <link rel="icon" href={`${base}images/favicons/favicon.ico`} sizes="any" />
    <link rel="icon" type="image/png" sizes="96x96" href={`${base}images/favicons/favicon-96x96.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}images/favicons/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}manifest.json`} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#020617" id="meta-theme-color" />
    <link href={`${base}fonts/inter.css`} rel="stylesheet" />
    <link href={`${base}fonts/finalf.css`} rel="stylesheet" />
    <script is:inline src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js" defer
    ></script>
    <title>{title}</title>

    <script is:inline type="application/ld+json" set:html={safeJsonLd(defaultSchema)} />

    <!-- Runs synchronously before first paint to apply the saved theme without a flash. -->
    <script is:inline>
      (function () {
        try {
          var key = document.documentElement.dataset.themeKey || 'portfolio-theme';
          var t = localStorage.getItem(key);
          if (t === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
            document.documentElement.style.background = '#f8fafc';
            var m = document.getElementById('meta-theme-color');
            if (m) m.setAttribute('content', '#f8fafc');
          } else {
            document.documentElement.style.background = '#020617';
          }
        } catch {}
      })();
    </script>
    <script is:inline>
      document.addEventListener('visibilitychange', function () {
        document.body.classList.toggle('page-hidden', document.hidden);
      });
    </script>
    <script is:inline>
      (function () {
        var savedTheme = null;
        window.addEventListener('beforeprint', function () {
          try {
            var key = document.documentElement.dataset.themeKey || 'portfolio-theme';
            savedTheme = localStorage.getItem(key);
          } catch {}
          document.documentElement.removeAttribute('data-theme');
        });
        window.addEventListener('afterprint', function () {
          if (savedTheme === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          }
          savedTheme = null;
        });
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
