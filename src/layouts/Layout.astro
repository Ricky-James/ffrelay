---
import '../styles/global.css';
import siteData from '../data/site.json';
import eventData from '../data/event.json';
import {
  canonicalPath,
  localeFromAstro,
  otherLocale,
  pathInOtherLocale,
  tField,
  type Locale,
} from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  lang?: Locale;
}

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const lang = Astro.props.lang ?? localeFromAstro(Astro);

const localizedTitle = tField(siteData, 'title', lang);
const localizedDescription = tField(siteData, 'description', lang);
const localizedOgSiteName = tField(siteData, 'ogSiteName', lang);
const localizedEventName = tField(eventData, 'name', lang);
const localizedTagline = tField(eventData, 'tagline', lang);

const { title = localizedTitle, description = localizedDescription } = Astro.props;

const siteOrigin = Astro.site?.origin ?? eventData.url;
// Clean-URL form so canonical matches the hreflang alternates and the nav links.
const canonicalURL = `${siteOrigin}${canonicalPath(Astro.url.pathname, lang)}`;
const altOtherURL = `${siteOrigin}${pathInOtherLocale(Astro.url.pathname, lang)}`;
const enURL = lang === 'en' ? canonicalURL : altOtherURL;

const otherLang = otherLocale(lang);
const ogLocale = lang === 'ja' ? 'ja_JP' : 'en_US';
const ogLocaleAlternate = otherLang === 'ja' ? 'ja_JP' : 'en_US';

const sameAsLinks = [
  eventData.twitch && `https://twitch.tv/${eventData.twitch}`,
  eventData.youtube && `https://youtube.com/@${eventData.youtube}`,
].filter(Boolean) as string[];

const defaultSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Event",
      "@id": `${eventData.url}/#event`,
      name: localizedEventName,
      description: localizedTagline,
      url: eventData.url,
      eventStatus: "https://schema.org/EventScheduled",
      eventAttendanceMode: "https://schema.org/OnlineEventAttendanceMode",
      sameAs: sameAsLinks,
      inLanguage: lang === 'ja' ? 'ja' : 'en',
    },
    {
      "@type": "WebSite",
      "@id": `${eventData.url}/#website`,
      name: localizedTitle,
      description: description,
      url: eventData.url,
      inLanguage: lang === 'ja' ? 'ja' : 'en',
    },
  ],
};

function safeJsonLd(obj: object): string {
  return JSON.stringify(obj).replace(/<\/script>/gi, "<\\/script>");
}
---

<!doctype html>
<html lang={lang} style="color-scheme: dark; background: #020617;" data-theme-key={siteData.themeStorageKey} data-locale={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content={localizedEventName} />
    <meta name="application-name" content={localizedOgSiteName} />
    <meta name="color-scheme" content="dark light" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={lang === 'en' ? canonicalURL : altOtherURL} />
    <link rel="alternate" hreflang="ja" href={lang === 'ja' ? canonicalURL : altOtherURL} />
    <link rel="alternate" hreflang="x-default" href={enURL} />

    <meta property="og:type"         content="website" />
    <meta property="og:url"          content={canonicalURL} />
    <meta property="og:title"        content={title} />
    <meta property="og:description"  content={description} />
    <meta property="og:site_name"    content={localizedOgSiteName} />
    <meta property="og:locale"       content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href={`${base}images/favicons/favicon.svg`} />
    <link rel="icon" href={`${base}images/favicons/favicon.ico`} sizes="any" />
    <link rel="icon" type="image/png" sizes="96x96" href={`${base}images/favicons/favicon-96x96.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}images/favicons/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}manifest.json`} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#020617" id="meta-theme-color" />
    <link href={`${base}fonts/inter.css`} rel="stylesheet" />
    <link href={`${base}fonts/finalf.css`} rel="stylesheet" />
    <script is:inline src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js" defer
    ></script>
    <title>{title}</title>

    <script is:inline type="application/ld+json" set:html={safeJsonLd(defaultSchema)} />

    <!-- Runs synchronously before first paint to apply the saved theme without a flash. -->
    <script is:inline>
      (function () {
        try {
          var key = document.documentElement.dataset.themeKey || 'portfolio-theme';
          var t = localStorage.getItem(key);
          if (t === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
            document.documentElement.style.background = '#f8fafc';
            var m = document.getElementById('meta-theme-color');
            if (m) m.setAttribute('content', '#f8fafc');
          } else {
            document.documentElement.style.background = '#020617';
          }
        } catch {}
      })();
    </script>
    <script is:inline>
      document.addEventListener('visibilitychange', function () {
        document.body.classList.toggle('page-hidden', document.hidden);
      });
    </script>
    <script is:inline>
      (function () {
        var savedTheme = null;
        window.addEventListener('beforeprint', function () {
          try {
            var key = document.documentElement.dataset.themeKey || 'portfolio-theme';
            savedTheme = localStorage.getItem(key);
          } catch {}
          document.documentElement.removeAttribute('data-theme');
        });
        window.addEventListener('afterprint', function () {
          if (savedTheme === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          }
          savedTheme = null;
        });
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
